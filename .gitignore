# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# sitemap
public/sitemap.xml
public/sitemap-*.xml
/public/robots.txt

# Image index files
/public/images/**/index.json

# Generated files (pnpm prebuild)
/public/generated/

# Draft posts
/draft_posts

# Cache files
.posts.cache.json
.posts.metadata.json
.posts.content.json

# Lighthouse reports
/lighthouse-report.report.html
/lighthouse-report.report.json
/lighthouse-*.json
/lighthouse-*.html
/.lighthouseci/

# Local Netlify folder
.netlify

